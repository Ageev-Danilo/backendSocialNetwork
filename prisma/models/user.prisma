model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String  
  surname   String  
  username  String   @unique 
  avatar    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile   Profile?
  posts     Post[]
  albums    Album[]

  contacts  Contact[]
  chats     Chat[]

  likedPosts Post[] @relation("PostLikes")
  viewedPosts Post[] @relation("PostViews")
}